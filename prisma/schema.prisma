// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Tour {
  id          String    @id @default(uuid())
  shopifyId   String?
  title       String
  bookings    Booking[]
  createdAt   DateTime  @default(now())
}

model Booking {
  id            String   @id @default(uuid())
  tourId        String
  tour          Tour     @relation(fields: [tourId], references: [id])
  customerName  String
  customerEmail String?
  customerPhone String?
  language      String?
  startTime     DateTime
  platform      String
  status        String   @default("CONFIRMED")
  createdAt     DateTime @default(now())
}

model Guide {
  id        String   @id @default(uuid())
  name      String
  email     String?
  whatsapp  String
  photoUrl  String?
  createdAt DateTime @default(now())
}

model BlockedDate {
  id          String    @id @default(uuid())
  tourId      String?
  date        DateTime?
  dayOfWeek   String?
  timeSlot    String?
  createdAt   DateTime  @default(now())
}

model Media {
  id        String   @id @default(uuid())
  url       String
  filename  String
  mimetype  String
  category  String   @default("general")
  label     String?
  createdAt DateTime @default(now())
}
